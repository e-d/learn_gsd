---
const base = import.meta.env.BASE_URL;
---

<header class="border-b border-border">
	<div class="mx-auto max-w-[1100px] px-6 py-4 flex items-center justify-between">
		<a href={base} class="text-heading text-lg font-semibold tracking-tight hover:text-accent transition-colors">
			Learn GSD
		</a>
		<nav>
			<a
				href={`${base}#tutorials`}
				class="text-sm transition-colors text-text-muted hover:text-text"
			>
				Tutorials
			</a>
		</nav>
	</div>
</header>
