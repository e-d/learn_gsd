		/>

		<p class="text-text mb-6">
			When Claude Code launches, you'll see a prompt waiting for your instruction. That's it — no config files, no extension setup, no IDE integration required. Just a terminal and a conversation.
		</p>
	</section>

	<!-- Section 3: Your First Session -->
	<section class="mb-16">
		<h2 class="text-2xl font-semibold text-heading mb-4">Your First Session</h2>
		<p class="text-text mb-4">
			Let's start simple. With Claude Code running in your <code class="text-accent">task-tracker</code> directory, type a prompt describing what you want to build.
		</p>

		<div class="rounded-lg border border-border bg-surface p-6 mb-6">
			<p class="text-text-muted text-sm mb-2">Your prompt:</p>
			<p class="text-text font-mono text-sm">
				Create a task tracker CLI in <span class="text-accent">[Python or TypeScript]</span>. I should be able to add tasks with a title, list all tasks, and mark tasks as complete. Store tasks in a local JSON file.
			</p>
		</div>

		<div class="rounded-lg border border-accent/30 bg-accent/5 p-4 mb-6">
			<p class="text-text text-sm">
				<strong class="text-accent">Note:</strong> Specify the language you want in your prompt — Claude Code will use idiomatic libraries for that language (Python or TypeScript). The code examples in this tutorial show both variants; pick whatever language you want, you just won't have examples here.
			</p>
		</div>

		<p class="text-text mb-4">
			Watch what happens. Claude Code will:
		</p>
		<ol class="text-text mb-6 list-decimal list-inside space-y-2 pl-2">
			<li>Read your project structure to understand what exists</li>
			<li>Create the source files with the CLI logic</li>
			<li>Write the JSON storage layer</li>
			<li>Test the commands to verify they work</li>
		</ol>

		<p class="text-text mb-4">
			Here's roughly what Claude Code will generate:
		</p>

		<CodeGroup
			title="task-tracker — the main CLI entry point"
			python={`#!/usr/bin/env python3
"""Task tracker CLI — add, list, and complete tasks."""

import json
import sys
from pathlib import Path

import click

TASKS_FILE = Path("tasks.json")


def load_tasks() -> list[dict]:
    if TASKS_FILE.exists():
        return json.loads(TASKS_FILE.read_text())
    return []


def save_tasks(tasks: list[dict]) -> None:
    TASKS_FILE.write_text(json.dumps(tasks, indent=2))


@click.group()
def cli():
    """A simple task tracker."""
    pass


@cli.command()
@click.argument("title")
def add(title: str):
    """Add a new task."""
    tasks = load_tasks()
    task = {
        "id": len(tasks) + 1,
        "title": title,
        "done": False,
    }
    tasks.append(task)
    save_tasks(tasks)
    click.echo(f"Added task {task['id']}: {title}")


@cli.command(name="list")
def list_tasks():
    """List all tasks."""
    tasks = load_tasks()
    if not tasks:
        click.echo("No tasks yet. Add one with: task-tracker add 'My task'")
        return
    for task in tasks:
        status = "x" if task["done"] else " "
        click.echo(f"[{status}] {task['id']}: {task['title']}")


@cli.command()
@click.argument("task_id", type=int)
def done(task_id: int):
    """Mark a task as complete."""
    tasks = load_tasks()
    for task in tasks:
        if task["id"] == task_id:
            task["done"] = True
            save_tasks(tasks)
            click.echo(f"Completed: {task['title']}")
            return
    click.echo(f"Task {task_id} not found.", err=True)
    sys.exit(1)


if __name__ == "__main__":
    cli()`}
			typescript={`#!/usr/bin/env node
// Task tracker CLI — add, list, and complete tasks.

import { Command } from "commander";
import { readFileSync, writeFileSync, existsSync } from "fs";

const TASKS_FILE = "tasks.json";

interface Task {
  id: number;
  title: string;
  done: boolean;
}

function loadTasks(): Task[] {
  if (existsSync(TASKS_FILE)) {
    return JSON.parse(readFileSync(TASKS_FILE, "utf-8"));
  }
  return [];
}

function saveTasks(tasks: Task[]): void {
  writeFileSync(TASKS_FILE, JSON.stringify(tasks, null, 2));
}

const program = new Command();
program.name("task-tracker").description("A simple task tracker.");

program
  .command("add <title>")
  .description("Add a new task")
  .action((title: string) => {
    const tasks = loadTasks();
    const task: Task = {
      id: tasks.length + 1,
      title,
      done: false,
    };
    tasks.push(task);
    saveTasks(tasks);
    console.log(\`Added task \${task.id}: \${title}\`);
  });

program
  .command("list")
  .description("List all tasks")
  .action(() => {
    const tasks = loadTasks();
    if (tasks.length === 0) {
      console.log("No tasks yet. Add one with: task-tracker add 'My task'");
      return;
    }
    for (const task of tasks) {
      const status = task.done ? "x" : " ";
      console.log(\`[\${status}] \${task.id}: \${task.title}\`);
    }
  });

program
  .command("done <taskId>")
  .description("Mark a task as complete")
  .action((taskId: string) => {
    const tasks = loadTasks();
    const task = tasks.find((t) => t.id === parseInt(taskId));
    if (!task) {
      console.error(\`Task \${taskId} not found.\`);
      process.exit(1);
    }
    task.done = true;
    saveTasks(tasks);
    console.log(\`Completed: \${task.title}\`);
  });

program.parse();`}
		/>

		<p class="text-text mb-4">
