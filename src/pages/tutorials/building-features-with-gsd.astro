		/>

		<p class="text-text mb-4">
			The plan passes verification. GSD creates an atomic commit for the completed work and moves to the next plan. Each plan gets its own commit — if something goes wrong later, you can bisect or revert individual changes cleanly.
		</p>

		<h3 class="text-lg font-semibold text-heading mb-3 mt-8">Fresh context, every time</h3>
		<p class="text-text mb-6">
			Here's something important about how GSD executes. Each plan runs with a <strong class="text-heading">fresh 200k-token context window</strong>. Plan 2 doesn't inherit the accumulated conversation from Plan 1 — it starts clean, reads only the plan file and the current code. This prevents the "context rot" problem where Claude Code gradually loses track of what's happening after hundreds of exchanges. The plan file carries the intent; the code carries the state. No stale context to confuse things.
		</p>
	</section>

	<!-- Section 5: Adding Due Dates -->
	<section class="mb-16">
		<h2 class="text-2xl font-semibold text-heading mb-4">Adding Due Dates and Filters</h2>
		<p class="text-text mb-4">
			Plans 2 and 3 add due dates and filtering. They follow the same loop — each gets a fresh context, executes against the current code (which now includes the priority changes from Plan 1), and verifies independently.
		</p>

		<CodeGroup
			title="Due dates and filtering"
			python={`from datetime import datetime, timezone, timedelta
from pathlib import Path
import json, sys, click

TASKS_FILE = Path("tasks.json")
VALID_PRIORITIES = ("high", "medium", "low")


def load_tasks() -> list[dict]:
    if TASKS_FILE.exists():
        return json.loads(TASKS_FILE.read_text())
    return []


def save_tasks(tasks: list[dict]) -> None:
    TASKS_FILE.write_text(json.dumps(tasks, indent=2))


def time_ago(iso_str: str) -> str:
    dt = datetime.fromisoformat(iso_str)
    delta = datetime.now(timezone.utc) - dt
    if delta.days > 0:
        return f"{delta.days}d ago"
    hours = delta.seconds // 3600
    if hours > 0:
        return f"{hours}h ago"
    return f"{delta.seconds // 60}m ago"


def priority_marker(priority: str) -> str:
    return {"high": "!!!", "medium": "!!", "low": "!"}.get(priority, "")


def is_overdue(task: dict) -> bool:
    due = task.get("due_date")
    if not due or task["done"]:
        return False
    return datetime.fromisoformat(due) < datetime.now(timezone.utc)


def format_due(task: dict) -> str:
    due = task.get("due_date")
    if not due:
        return ""
    dt = datetime.fromisoformat(due)
    label = dt.strftime("%b %d")
    if is_overdue(task):
        return f"OVERDUE {label}"
    delta = dt - datetime.now(timezone.utc)
    if delta.days <= 1:
        return f"due tomorrow"
    return f"due {label}"


@click.group()
def cli():
    """Task tracker with priorities and due dates."""
    pass


@cli.command()
@click.argument("title")
@click.option("-p", "--priority", type=click.Choice(VALID_PRIORITIES), default="medium")
@click.option("-d", "--due", "due_date", default=None, help="Due date (YYYY-MM-DD)")
def add(title: str, priority: str, due_date: str | None):
    """Add a new task."""
    tasks = load_tasks()
    due_iso = None
    if due_date:
        due_iso = datetime.strptime(due_date, "%Y-%m-%d").replace(
            tzinfo=timezone.utc
        ).isoformat()
    task = {
        "id": len(tasks) + 1,
        "title": title,
        "done": False,
        "priority": priority,
        "due_date": due_iso,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "completed_at": None,
    }
    tasks.append(task)
    save_tasks(tasks)
    click.echo(f"Added task {task['id']}: {title} [{priority}]")


@cli.command(name="list")
@click.option("-p", "--priority", type=click.Choice(VALID_PRIORITIES), default=None)
@click.option("--overdue", is_flag=True, help="Show only overdue tasks")
def list_tasks(priority: str | None, overdue: bool):
    """List tasks, optionally filtered."""
    tasks = load_tasks()
    if priority:
        tasks = [t for t in tasks if t.get("priority") == priority]
    if overdue:
        tasks = [t for t in tasks if is_overdue(t)]
    if not tasks:
        click.echo("No matching tasks.")
        return
    for task in tasks:
        status = "x" if task["done"] else " "
        age = time_ago(task["created_at"])
        marker = priority_marker(task.get("priority", "medium"))
        due = format_due(task)
        due_str = f"  {due}" if due else ""
        click.echo(f"[{status}] {task['id']}: {task['title']}  {marker}{due_str}  ({age})")


@cli.command()
@click.argument("task_id", type=int)
def done(task_id: int):
    """Mark a task as complete."""
    tasks = load_tasks()
    for task in tasks:
        if task["id"] == task_id:
            task["done"] = True
            task["completed_at"] = datetime.now(timezone.utc).isoformat()
            save_tasks(tasks)
            click.echo(f"Completed: {task['title']}")
            return
    click.echo(f"Task {task_id} not found.", err=True)
    sys.exit(1)


if __name__ == "__main__":
    cli()`}
			typescript={`#!/usr/bin/env node
// Task tracker CLI with priorities, due dates, and filtering.

import { Command } from "commander";
import { readFileSync, writeFileSync, existsSync } from "fs";

const TASKS_FILE = "tasks.json";

type Priority = "high" | "medium" | "low";

interface Task {
  id: number;
  title: string;
  done: boolean;
  priority: Priority;
  dueDate: string | null;
  createdAt: string;
  completedAt: string | null;
}

function loadTasks(): Task[] {
  if (existsSync(TASKS_FILE)) {
    return JSON.parse(readFileSync(TASKS_FILE, "utf-8"));
  }
  return [];
}

function saveTasks(tasks: Task[]): void {
  writeFileSync(TASKS_FILE, JSON.stringify(tasks, null, 2));
}

function timeAgo(isoStr: string): string {
  const delta = Date.now() - new Date(isoStr).getTime();
  const days = Math.floor(delta / 86_400_000);
  if (days > 0) return \`\${days}d ago\`;
  const hours = Math.floor(delta / 3_600_000);
  if (hours > 0) return \`\${hours}h ago\`;
  return \`\${Math.floor(delta / 60_000)}m ago\`;
}

function priorityMarker(p: Priority): string {
  return { high: "!!!", medium: "!!", low: "!" }[p] ?? "";
}

function isOverdue(task: Task): boolean {
  if (!task.dueDate || task.done) return false;
  return new Date(task.dueDate).getTime() < Date.now();
}

function formatDue(task: Task): string {
  if (!task.dueDate) return "";
  const dt = new Date(task.dueDate);
  const label = dt.toLocaleDateString("en-US", { month: "short", day: "numeric" });
  if (isOverdue(task)) return \`OVERDUE \${label}\`;
  const delta = dt.getTime() - Date.now();
  if (delta < 86_400_000) return "due tomorrow";
  return \`due \${label}\`;
}

const program = new Command();
program.name("task-tracker").description("Task tracker with priorities and due dates.");

program
  .command("add <title>")
  .description("Add a new task")
  .option("-p, --priority <level>", "Priority (high, medium, low)", "medium")
  .option("-d, --due <date>", "Due date (YYYY-MM-DD)")
  .action((title: string, opts: { priority: string; due?: string }) => {
    const priority = opts.priority as Priority;
    const dueDate = opts.due
      ? new Date(opts.due + "T00:00:00Z").toISOString()
      : null;
    const tasks = loadTasks();
    const task: Task = {
      id: tasks.length + 1,
      title,
      done: false,
      priority,
      dueDate,
      createdAt: new Date().toISOString(),
      completedAt: null,
    };
    tasks.push(task);
    saveTasks(tasks);
    console.log(\`Added task \${task.id}: \${title} [\${priority}]\`);
  });

program
  .command("list")
  .description("List tasks, optionally filtered")
  .option("-p, --priority <level>", "Filter by priority")
  .option("--overdue", "Show only overdue tasks")
  .action((opts: { priority?: string; overdue?: boolean }) => {
    let tasks = loadTasks();
    if (opts.priority) {
      tasks = tasks.filter((t) => t.priority === opts.priority);
    }
    if (opts.overdue) {
      tasks = tasks.filter(isOverdue);
    }
    if (tasks.length === 0) {
      console.log("No matching tasks.");
      return;
    }
    for (const task of tasks) {
      const status = task.done ? "x" : " ";
      const age = timeAgo(task.createdAt);
      const marker = priorityMarker(task.priority);
      const due = formatDue(task);
      const dueStr = due ? \`  \${due}\` : "";
      console.log(\`[\${status}] \${task.id}: \${task.title}  \${marker}\${dueStr}  (\${age})\`);
    }
  });

program
  .command("done <taskId>")
  .description("Mark a task as complete")
  .action((taskId: string) => {
    const tasks = loadTasks();
    const task = tasks.find((t) => t.id === parseInt(taskId));
    if (!task) {
      console.error(\`Task \${taskId} not found.\`);
      process.exit(1);
    }
    task.done = true;
    task.completedAt = new Date().toISOString();
    saveTasks(tasks);
    console.log(\`Completed: \${task.title}\`);
  });

program.parse();`}
		/>

