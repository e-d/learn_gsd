		<CodeGroup
			title="Extracted storage module"
			python={`# storage.py
"""Task persistence — JSON file storage."""

import json
from pathlib import Path

DEFAULT_FILE = Path("tasks.json")


class TaskStore:
    def __init__(self, path: Path = DEFAULT_FILE):
        self.path = path

    def load(self) -> list[dict]:
        if self.path.exists():
            return json.loads(self.path.read_text())
        return []

    def save(self, tasks: list[dict]) -> None:
        self.path.write_text(json.dumps(tasks, indent=2))

    def next_id(self, tasks: list[dict]) -> int:
        return max((t["id"] for t in tasks), default=0) + 1`}
			typescript={`// storage.ts
// Task persistence — JSON file storage.

import { readFileSync, writeFileSync, existsSync } from "fs";

const DEFAULT_FILE = "tasks.json";

export interface Task {
  id: number;
  title: string;
  done: boolean;
  priority: "high" | "medium" | "low";
  dueDate: string | null;
  createdAt: string;
  completedAt: string | null;
}

export class TaskStore {
  constructor(private path: string = DEFAULT_FILE) {}

  load(): Task[] {
    if (existsSync(this.path)) {
      return JSON.parse(readFileSync(this.path, "utf-8"));
    }
    return [];
  }

  save(tasks: Task[]): void {
    writeFileSync(this.path, JSON.stringify(tasks, null, 2));
  }

  nextId(tasks: Task[]): number {
    return Math.max(...tasks.map((t) => t.id), 0) + 1;
  }
}`}
		/>

