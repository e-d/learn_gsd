import json
import os
import pytest
from click.testing import CliRunner
from task_tracker import cli

TASKS_FILE = "tasks.json"


@pytest.fixture(autouse=True)
def clean_tasks(tmp_path, monkeypatch):
    """Run each test in a temp directory with no tasks file."""
    monkeypatch.chdir(tmp_path)
    yield
    if os.path.exists(TASKS_FILE):
        os.remove(TASKS_FILE)


@pytest.fixture
def runner():
    return CliRunner()


def read_tasks():
    with open(TASKS_FILE) as f:
        return json.load(f)


class TestAdd:
    def test_add_basic(self, runner):
        result = runner.invoke(cli, ["add", "Buy milk"])
        assert result.exit_code == 0
        assert "Added task 1" in result.output
        tasks = read_tasks()
        assert len(tasks) == 1
        assert tasks[0]["title"] == "Buy milk"
        assert tasks[0]["priority"] == "medium"

    def test_add_with_priority(self, runner):
        result = runner.invoke(cli, ["add", "Fix bug", "-p", "high"])
        assert result.exit_code == 0
        tasks = read_tasks()
        assert tasks[0]["priority"] == "high"

    def test_add_with_due_date(self, runner):
        result = runner.invoke(cli, ["add", "Ship it", "-d", "2026-12-31"])
        assert result.exit_code == 0
        tasks = read_tasks()
        assert tasks[0]["due_date"] is not None


class TestList:
    def test_list_empty(self, runner):
        result = runner.invoke(cli, ["list"])
        assert result.exit_code == 0
        assert "No matching tasks" in result.output or "No tasks" in result.output

    def test_list_shows_tasks(self, runner):
        runner.invoke(cli, ["add", "Task one"])
        runner.invoke(cli, ["add", "Task two"])
        result = runner.invoke(cli, ["list"])
        assert "Task one" in result.output
        assert "Task two" in result.output

    def test_list_filter_priority(self, runner):
        runner.invoke(cli, ["add", "Low task", "-p", "low"])
        runner.invoke(cli, ["add", "High task", "-p", "high"])
        result = runner.invoke(cli, ["list", "-p", "high"])
        assert "High task" in result.output
        assert "Low task" not in result.output


class TestDone:
    def test_mark_done(self, runner):
        runner.invoke(cli, ["add", "Finish this"])
        result = runner.invoke(cli, ["done", "1"])
        assert result.exit_code == 0
        assert "Completed" in result.output
        tasks = read_tasks()
        assert tasks[0]["done"] is True
        assert tasks[0]["completed_at"] is not None

    def test_done_not_found(self, runner):
        result = runner.invoke(cli, ["done", "999"])
        assert result.exit_code != 0`}
			typescript={`// task_tracker.test.ts
import { execSync } from "child_process";
import { readFileSync, existsSync, mkdtempSync, rmSync } from "fs";
import { join } from "path";
import { tmpdir } from "os";
import { describe, it, expect, beforeEach, afterEach } from "vitest";

const CLI = "npx tsx task_tracker.ts";
let testDir: string;

function run(args: string): string {
  return execSync(CLI + " " + args, {
    cwd: testDir,
    encoding: "utf-8",
    env: { ...process.env },
  }).trim();
}

function readTasks(): any[] {
  const file = join(testDir, "tasks.json");
  if (!existsSync(file)) return [];
  return JSON.parse(readFileSync(file, "utf-8"));
}

beforeEach(() => {
  testDir = mkdtempSync(join(tmpdir(), "task-tracker-"));
  execSync("cp task_tracker.ts " + testDir + "/");
});

afterEach(() => {
  rmSync(testDir, { recursive: true, force: true });
});

describe("add", () => {
  it("adds a task with default priority", () => {
    const output = run('add "Buy milk"');
    expect(output).toContain("Added task 1");
    const tasks = readTasks();
    expect(tasks).toHaveLength(1);
    expect(tasks[0].title).toBe("Buy milk");
    expect(tasks[0].priority).toBe("medium");
  });

  it("adds a task with custom priority", () => {
    run('add "Fix bug" --priority high');
    const tasks = readTasks();
    expect(tasks[0].priority).toBe("high");
  });

  it("adds a task with due date", () => {
    run('add "Ship it" --due 2026-12-31');
    const tasks = readTasks();
    expect(tasks[0].dueDate).toBeTruthy();
  });
});

describe("list", () => {
  it("shows empty message when no tasks", () => {
    const output = run("list");
    expect(output).toMatch(/no (matching )?tasks/i);
  });

  it("shows added tasks", () => {
    run('add "Task one"');
    run('add "Task two"');
    const output = run("list");
    expect(output).toContain("Task one");
    expect(output).toContain("Task two");
  });

  it("filters by priority", () => {
    run('add "Low task" --priority low');
    run('add "High task" --priority high');
    const output = run("list --priority high");
    expect(output).toContain("High task");
    expect(output).not.toContain("Low task");
  });
});

describe("done", () => {
  it("marks a task as complete", () => {
    run('add "Finish this"');
    const output = run("done 1");
    expect(output).toContain("Completed");
    const tasks = readTasks();
    expect(tasks[0].done).toBe(true);
    expect(tasks[0].completedAt).toBeTruthy();
  });

  it("exits with error for missing task", () => {
    expect(() => run("done 999")).toThrow();
  });
});`}
		/>

