	<!-- Section 5: Plan 3 — Separate Business Logic -->
	<section class="mb-16">
		<h2 class="text-2xl font-semibold text-heading mb-4">Plan 3: Separate Business Logic from CLI</h2>
		<p class="text-text mb-4">
			The final plan extracts the core logic — adding tasks, marking them done, filtering — into a service module. Again, this runs with a fresh context that reads the plan and the current code (now including the extracted storage module). The CLI file becomes a thin shell that parses arguments and calls the service.
		</p>

		<CodeGroup
			title="Task service — business logic separated from CLI"
			python={`# service.py
"""Task operations — business logic independent of CLI framework."""

from datetime import datetime, timezone
from storage import TaskStore


class TaskService:
    def __init__(self, store: TaskStore | None = None):
        self.store = store or TaskStore()

    def add_task(self, title: str, priority: str = "medium",
                 due_date: str | None = None) -> dict:
        tasks = self.store.load()
        due_iso = None
        if due_date:
            due_iso = datetime.strptime(due_date, "%Y-%m-%d").replace(
                tzinfo=timezone.utc
            ).isoformat()
        task = {
            "id": self.store.next_id(tasks),
            "title": title,
            "done": False,
            "priority": priority,
            "due_date": due_iso,
            "created_at": datetime.now(timezone.utc).isoformat(),
            "completed_at": None,
        }
        tasks.append(task)
        self.store.save(tasks)
        return task

    def list_tasks(self, priority: str | None = None,
                   overdue_only: bool = False) -> list[dict]:
        tasks = self.store.load()
        if priority:
            tasks = [t for t in tasks if t.get("priority") == priority]
        if overdue_only:
            tasks = [t for t in tasks if self.is_overdue(t)]
        return tasks

    def complete_task(self, task_id: int) -> dict | None:
        tasks = self.store.load()
        for task in tasks:
            if task["id"] == task_id:
                task["done"] = True
                task["completed_at"] = datetime.now(timezone.utc).isoformat()
                self.store.save(tasks)
                return task
        return None

    @staticmethod
    def is_overdue(task: dict) -> bool:
        due = task.get("due_date")
        if not due or task["done"]:
            return False
        return datetime.fromisoformat(due) < datetime.now(timezone.utc)`}
			typescript={`// service.ts
// Task operations — business logic independent of CLI framework.

import { TaskStore } from "./storage";
import type { Task } from "./storage";

export class TaskService {
  constructor(private store: TaskStore = new TaskStore()) {}

  addTask(title: string, priority: Task["priority"] = "medium",
          dueDate?: string): Task {
    const tasks = this.store.load();
    const dueDateIso = dueDate
      ? new Date(dueDate + "T00:00:00Z").toISOString()
      : null;
    const task: Task = {
      id: this.store.nextId(tasks),
      title,
      done: false,
      priority,
      dueDate: dueDateIso,
      createdAt: new Date().toISOString(),
      completedAt: null,
    };
    tasks.push(task);
    this.store.save(tasks);
    return task;
  }

  listTasks(priority?: Task["priority"],
            overdueOnly: boolean = false): Task[] {
    let tasks = this.store.load();
    if (priority) {
      tasks = tasks.filter((t) => t.priority === priority);
    }
    if (overdueOnly) {
      tasks = tasks.filter((t) => this.isOverdue(t));
    }
    return tasks;
  }

  completeTask(taskId: number): Task | null {
    const tasks = this.store.load();
    const task = tasks.find((t) => t.id === taskId);
    if (!task) return null;
    task.done = true;
    task.completedAt = new Date().toISOString();
    this.store.save(tasks);
    return task;
  }

  isOverdue(task: Task): boolean {
    if (!task.dueDate || task.done) return false;
    return new Date(task.dueDate).getTime() < Date.now();
  }
}`}
		/>

